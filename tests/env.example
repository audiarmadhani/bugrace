# Copy to .env.test.local in the project root and fill in values.
# Used by Playwright (see docs/PLAYWRIGHT.md).

# App URL — local dev or production
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# Set to 1 when the app is already running (skips `npm run dev` in playwright.config)
# PLAYWRIGHT_SKIP_WEBSERVER=1

# Platform account (BugRace login — not ShopVerse)
TEST_PLATFORM_EMAIL=you@example.com
TEST_PLATFORM_PASSWORD=your-platform-password

# Supabase service role — required to reveal today's bug_id (QA only, never commit real keys)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
